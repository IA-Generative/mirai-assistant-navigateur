{
  "configVersion": 1,
  "slug": "mirai-browser",
  "activeProfile": "prod",
  "default": {
    "portal_url": "https://mirai.interieur.gouv.fr",
    "doc_url": "https://github.com/IA-Generative/AssistantMiraiLibreOffice/blob/master/docs/notice-utilisateur.md",
    "enabled": true,
    "telemetryEnabled": true,
    "telemetrylogJson": true,
    "telemetryAuthorizationType": "Bearer",
    "authHeaderName": "Authorization",
    "authHeaderPrefix": "Bearer ",
    "allowedKeywords": ["webconf", "visio", "comu", "webinaire", "webex", "gmeet", "teams"]
  },
  "dev": {
    "_description": "Dev avec DM Docker Compose local",
    "bootstrap_url": "http://localhost:3001",
    "config_path": "/config/mirai-browser/config.json?profile=dev",
    "relayAssistantBaseUrl": "http://localhost:8088/relay-assistant",
    "keycloakIssuerUrl": "http://localhost:8082",
    "keycloakRealm": "openwebui",
    "keycloakClientId": "bootstrap-iassistant",
    "keycloak_redirect_uri": "${{KEYCLOAK_REDIRECT_URI}}",
    "keycloak_allowed_redirect_uri": "${{KEYCLOAK_ALLOWED_REDIRECT_URI}}",
    "apiBase": "http://localhost:8080/api",
    "chatUrl": "http://localhost:3000/",
    "resumeUrl": "http://localhost:3001/",
    "compteRenduUrl": "http://localhost:8080/",
    "aideUrl": "http://localhost:3002/aide",
    "comuUrl": "https://webconf.comu.gouv.fr/"
  },
  "int": {
    "_description": "Integration / recette",
    "bootstrap_url": "https://bootstrap.fake-domain.name",
    "config_path": "/config/mirai-browser/config.json?profile=int",
    "relayAssistantBaseUrl": "https://bootstrap.fake-domain.name/relay-assistant",
    "keycloakIssuerUrl": "${{KEYCLOAK_ISSUER_URL}}",
    "keycloakRealm": "${{KEYCLOAK_REALM}}",
    "keycloakClientId": "mirai-extension",
    "keycloak_redirect_uri": "${{KEYCLOAK_REDIRECT_URI}}",
    "keycloak_allowed_redirect_uri": "${{KEYCLOAK_ALLOWED_REDIRECT_URI}}",
    "apiBase": "https://compte-rendu.mirai.interieur.gouv.fr/api",
    "chatUrl": "https://chat.mirai.interieur.gouv.fr/",
    "resumeUrl": "https://resume.mirai.interieur.gouv.fr/",
    "compteRenduUrl": "https://compte-rendu.mirai.interieur.gouv.fr/",
    "aideUrl": "https://mirai.interieur.gouv.fr/aide",
    "comuUrl": "https://webconf.comu.gouv.fr/"
  },
  "prod": {
    "_description": "Production",
    "bootstrap_url": "https://bootstrap.fake-domain.name",
    "config_path": "/config/mirai-browser/config.json?profile=prod",
    "relayAssistantBaseUrl": "https://bootstrap.fake-domain.name/relay-assistant",
    "keycloakIssuerUrl": "https://sso.mirai.interieur.gouv.fr/",
    "keycloakRealm": "mirai",
    "keycloakClientId": "mirai-extension",
    "keycloak_redirect_uri": "${{KEYCLOAK_REDIRECT_URI}}",
    "keycloak_allowed_redirect_uri": "${{KEYCLOAK_ALLOWED_REDIRECT_URI}}",
    "apiBase": "https://compte-rendu.mirai.interieur.gouv.fr/api",
    "chatUrl": "https://chat.mirai.interieur.gouv.fr/",
    "resumeUrl": "https://resume.mirai.interieur.gouv.fr/",
    "compteRenduUrl": "https://compte-rendu.mirai.interieur.gouv.fr/",
    "aideUrl": "https://mirai.interieur.gouv.fr/aide",
    "comuUrl": "https://webconf.comu.gouv.fr/"
  }
}
