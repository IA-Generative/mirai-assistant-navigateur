{
  "key": "",
  "manifest_version": 3,
  "name": "MirAI Recorder",
  "version": "1.2.0",
  "description": "MirAI Recorder – capture, enregistrement et intégration sécurisée des réunions (Chrome/Firefox, Manifest V2/V3).",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "tabs",
    "storage",
    "identity",
    "activeTab"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "web_accessible_resources": [
    {
      "resources": [
        "compat.js",
        "popup.html",
        "options.html",
        "icons/icon16.png",
        "icons/icon48.png",
        "icons/icon128.png"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "mirai-assistant@interieur.gouv.fr",
      "strict_min_version": "128.11.0"
    }
  }
}